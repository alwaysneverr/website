---
layout: empty
---

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or meta.title }}</title>

    {% include "meta.njk" %}
    <link rel="stylesheet" href="/assets/css/main.scss">
    <link rel="preload" href="/assets/fonts/merriweather/merriweather-v33-latin-regular.woff2" as="font" type="font/woff2">
</head>

<body class="container">
    <header>
        <nav>
            <span>
                <form action="/fiction/">
                    <input type="submit" value="Back" />
                </form>
            </span>
            <span>
                <button type="button" data-theme-toggle aria-label="Change to light theme"
                    class="theme_toggle light-theme" style="float: right;"></button>
            </span>
        </nav>
    </header>
    <main class="merriweather-regular">
        {{ content | safe }}
    </main>
    
    {% include "footer.njk" %}

    <script type="module" src="{{ '/assets/js/main.js' | url }}"></script>
</body>
